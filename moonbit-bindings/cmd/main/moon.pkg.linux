import {
  "username/gpui-bindings",
  "username/gpui-bindings/app",
}

options(
  "is-main": true,
  link: {
    "native": {
      "cc-flags": "-I../gpui-sys/include",
      "cc-link-flags": "-L../gpui-sys/target/debug -L../.linux-libs -lgpui_sys -lstdc++ -l:libxcb.so.1 -l:libxcb-xkb.so.1 -l:libxkbcommon.so.0 -l:libxkbcommon-x11.so.0 -ldl -lgcc_s -lutil -lrt -lpthread -lm -lc",
    },
  },
)
